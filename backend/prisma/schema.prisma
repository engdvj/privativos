generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  setor
  superadmin
  admin
}

enum StatusItem {
  disponivel
  emprestado
  inativo
}

model Funcionario {
  id          Int      @id @default(autoincrement())
  matricula   String   @unique @db.VarChar(20)
  nome        String   @db.VarChar(150)
  unidade     String   @db.VarChar(100)
  setor       String   @db.VarChar(100)
  funcao      String   @db.VarChar(100)
  statusAtivo Boolean  @default(true) @map("status_ativo")
  criadoEm    DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoPor String? @map("atualizado_por") @db.VarChar(150)
  atualizadoEm DateTime? @map("atualizado_em") @db.Timestamptz(6)

  itens Item[]
  unidades FuncionarioUnidade[]
  setores FuncionarioSetor[]
  funcoes FuncionarioFuncao[]

  @@index([matricula], map: "idx_funcionarios_matricula")
  @@map("funcionarios")
}

model Setor {
  id           Int       @id @default(autoincrement())
  nome         String    @unique @db.VarChar(100)
  statusAtivo  Boolean   @default(true) @map("status_ativo")
  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoPor String?  @map("atualizado_por") @db.VarChar(150)
  atualizadoEm DateTime? @map("atualizado_em") @db.Timestamptz(6)

  unidades    SetorUnidade[]
  funcionarios FuncionarioSetor[]

  @@map("setores")
}

model Unidade {
  id           Int       @id @default(autoincrement())
  nome         String    @unique @db.VarChar(100)
  statusAtivo  Boolean   @default(true) @map("status_ativo")
  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoPor String?  @map("atualizado_por") @db.VarChar(150)
  atualizadoEm DateTime? @map("atualizado_em") @db.Timestamptz(6)

  setores      SetorUnidade[]
  funcionarios FuncionarioUnidade[]

  @@map("unidades")
}

model SetorUnidade {
  id        Int      @id @default(autoincrement())
  setorId   Int      @map("setor_id")
  unidadeId Int      @map("unidade_id")
  criadoEm  DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  setor   Setor   @relation(fields: [setorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  unidade Unidade @relation(fields: [unidadeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([setorId, unidadeId], map: "setor_unidades_setor_id_unidade_id_key")
  @@index([setorId], map: "idx_setor_unidades_setor")
  @@index([unidadeId], map: "idx_setor_unidades_unidade")
  @@map("setor_unidades")
}

model FuncionarioSetor {
  id                 Int      @id @default(autoincrement())
  funcionarioMatricula String   @map("funcionario_matricula") @db.VarChar(20)
  setorId            Int      @map("setor_id")
  criadoEm           DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  funcionario Funcionario @relation(fields: [funcionarioMatricula], references: [matricula], onDelete: Cascade, onUpdate: Cascade)
  setor       Setor       @relation(fields: [setorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([funcionarioMatricula, setorId], map: "funcionario_setores_funcionario_matricula_setor_id_key")
  @@index([funcionarioMatricula], map: "idx_funcionario_setores_funcionario")
  @@index([setorId], map: "idx_funcionario_setores_setor")
  @@map("funcionario_setores")
}

model FuncionarioUnidade {
  id                 Int      @id @default(autoincrement())
  funcionarioMatricula String   @map("funcionario_matricula") @db.VarChar(20)
  unidadeId          Int      @map("unidade_id")
  criadoEm           DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  funcionario Funcionario @relation(fields: [funcionarioMatricula], references: [matricula], onDelete: Cascade, onUpdate: Cascade)
  unidade     Unidade     @relation(fields: [unidadeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([funcionarioMatricula, unidadeId], map: "funcionario_unidades_funcionario_matricula_unidade_id_key")
  @@index([funcionarioMatricula], map: "idx_funcionario_unidades_funcionario")
  @@index([unidadeId], map: "idx_funcionario_unidades_unidade")
  @@map("funcionario_unidades")
}

model Funcao {
  id           Int       @id @default(autoincrement())
  nome         String    @unique @db.VarChar(100)
  statusAtivo  Boolean   @default(true) @map("status_ativo")
  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoPor String?  @map("atualizado_por") @db.VarChar(150)
  atualizadoEm DateTime? @map("atualizado_em") @db.Timestamptz(6)

  funcionarios FuncionarioFuncao[]

  @@map("funcoes")
}

model FuncionarioFuncao {
  id                 Int      @id @default(autoincrement())
  funcionarioMatricula String   @map("funcionario_matricula") @db.VarChar(20)
  funcaoId           Int      @map("funcao_id")
  criadoEm           DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  funcionario Funcionario @relation(fields: [funcionarioMatricula], references: [matricula], onDelete: Cascade, onUpdate: Cascade)
  funcao      Funcao      @relation(fields: [funcaoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([funcionarioMatricula, funcaoId], map: "funcionario_funcoes_funcionario_matricula_funcao_id_key")
  @@index([funcionarioMatricula], map: "idx_funcionario_funcoes_funcionario")
  @@index([funcaoId], map: "idx_funcionario_funcoes_funcao")
  @@map("funcionario_funcoes")
}

model Item {
  id                   Int       @id @default(autoincrement())
  codigo               String    @unique @db.VarChar(50)
  descricao            String?   @db.VarChar(200)
  tipo                 String    @default("Sem tipo") @db.VarChar(100)
  tamanho              String    @default("UNICO") @db.VarChar(20)
  status               StatusItem
  solicitanteMatricula String?   @map("solicitante_matricula") @db.VarChar(20)
  setorSolicitante     String?   @map("setor_solicitante") @db.VarChar(100)
  dataEmprestimo       DateTime? @map("data_emprestimo") @db.Timestamptz(6)
  statusAtivo          Boolean   @default(true) @map("status_ativo")
  criadoEm             DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoPor        String?   @map("atualizado_por") @db.VarChar(150)
  atualizadoEm         DateTime? @map("atualizado_em") @db.Timestamptz(6)

  funcionario Funcionario? @relation(fields: [solicitanteMatricula], references: [matricula])

  @@index([status], map: "idx_itens_status")
  @@index([solicitanteMatricula], map: "idx_itens_solicitante")
  @@index([setorSolicitante], map: "idx_itens_setor_solicitante")
  @@index([tipo, tamanho, status, statusAtivo], map: "idx_itens_tipo_tamanho_status_ativo")
  @@map("itens")
}

model Solicitacao {
  id             Int      @id @default(autoincrement())
  timestamp      DateTime @default(now()) @db.Timestamptz(6)
  matricula      String   @db.VarChar(20)
  nomeFuncionario String  @map("nome_funcionario") @db.VarChar(150)
  itemCodigo     String   @map("item_codigo") @db.VarChar(50)
  operadorNome   String   @map("operador_nome") @db.VarChar(150)
  origemOperacao String   @default("colaborador") @map("origem_operacao") @db.VarChar(20)
  setorSolicitante String? @map("setor_solicitante") @db.VarChar(100)

  @@index([matricula], map: "idx_solicitacoes_matricula")
  @@index([timestamp], map: "idx_solicitacoes_timestamp")
  @@index([origemOperacao], map: "idx_solicitacoes_origem_operacao")
  @@index([setorSolicitante], map: "idx_solicitacoes_setor_solicitante")
  @@map("solicitacoes")
}

model Devolucao {
  id             Int      @id @default(autoincrement())
  timestamp      DateTime @default(now()) @db.Timestamptz(6)
  matricula      String   @db.VarChar(20)
  nomeFuncionario String  @map("nome_funcionario") @db.VarChar(150)
  itemCodigo     String   @map("item_codigo") @db.VarChar(50)
  operadorNome   String   @map("operador_nome") @db.VarChar(150)
  origemOperacao String   @default("colaborador") @map("origem_operacao") @db.VarChar(20)
  setorSolicitante String? @map("setor_solicitante") @db.VarChar(100)

  @@index([matricula], map: "idx_devolucoes_matricula")
  @@index([timestamp], map: "idx_devolucoes_timestamp")
  @@index([origemOperacao], map: "idx_devolucoes_origem_operacao")
  @@index([setorSolicitante], map: "idx_devolucoes_setor_solicitante")
  @@map("devolucoes")
}

model Credencial {
  id               Int       @id @default(autoincrement())
  usuario          String    @unique @db.VarChar(100)
  senhaHash        String    @map("senha_hash") @db.VarChar(255)
  perfil           Perfil
  nomeCompleto     String    @map("nome_completo") @db.VarChar(150)
  ativo            Boolean   @default(true)
  deveAlterarSenha Boolean   @default(true) @map("deve_alterar_senha")
  temaPreferido    String    @default("light") @map("tema_preferido") @db.VarChar(10)
  criadoEm         DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  criadoPor        String    @map("criado_por") @db.VarChar(150)
  atualizadoPor    String?   @map("atualizado_por") @db.VarChar(150)
  atualizadoEm     DateTime? @map("atualizado_em") @db.Timestamptz(6)

  @@map("credenciais")
}

model Configuracao {
  chave         String    @id @db.VarChar(100)
  valor         String    @db.VarChar(255)
  atualizadoPor String?   @map("atualizado_por") @db.VarChar(150)
  atualizadoEm  DateTime? @map("atualizado_em") @db.Timestamptz(6)

  @@map("configuracoes")
}

model Auditoria {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  operador   String   @db.VarChar(150)
  entidade   String   @db.VarChar(50)
  operacao   String   @db.VarChar(20)
  registroId String   @map("registro_id") @db.VarChar(100)
  dadosAntes Json?    @map("dados_antes")
  dadosDepois Json?   @map("dados_depois")

  @@map("auditoria")
}
